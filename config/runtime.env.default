# Runtime/security settings persisted beside the SQLite database.
# Existing config/runtime.env values win; new keys are appended automatically.
BILI_PUBLIC_BASE_URL=
BILI_TRUSTED_HOSTS=127.0.0.1,localhost,testserver
BILI_TRUSTED_PROXY_IPS=127.0.0.1
BILI_ALLOW_IP_HOSTS=true
BILI_COOKIE_SECURE=
BILI_HSTS=
BILI_EXPORT_TTL_SEC=86400
BILI_MIN_FREE_GIB=1
BILI_DOWNLOAD_CONCURRENCY=1
BILI_TRANSCODE_THREADS=0
